{
  "id": "symmetric-tree",
  "title": "Check if Binary Tree is Symmetric",
  "difficulty": "Easy",
  "tags": [
    "tree",
    "recursion"
  ],
  "description": "Check if a binary tree is a mirror of itself (symmetric around center).",
  "examples": [
    {
      "input": "root = [1,2,2,3,4,4,3]",
      "output": "true"
    }
  ],
  "starterCode": "function isSymmetric(root) {\n  // your code here\n}",
  "solution": "function isSymmetric(root) {\n  const isMirror = (t1, t2) => {\n    if (!t1 && !t2) return true;\n    if (!t1 || !t2) return false;\n    return t1.val === t2.val && isMirror(t1.left, t2.right) && isMirror(t1.right, t2.left);\n  };\n  \n  return isMirror(root, root);\n}",
  "hints": [
    "Compare left and right subtrees",
    "Check if they are mirrors of each other",
    "Use helper function for recursion"
  ],
  "testCases": [
    {
      "input": [
        {
          "val": 1,
          "left": {
            "val": 2,
            "left": {
              "val": 3,
              "left": null,
              "right": null
            },
            "right": {
              "val": 4,
              "left": null,
              "right": null
            }
          },
          "right": {
            "val": 2,
            "left": {
              "val": 4,
              "left": null,
              "right": null
            },
            "right": {
              "val": 3,
              "left": null,
              "right": null
            }
          }
        }
      ],
      "expected": true
    }
  ],
  "functionName": "isSymmetric",
  "xpReward": 90
}