{
  "id": "invert-tree",
  "title": "Invert Binary Tree",
  "difficulty": "Easy",
  "tags": [
    "tree",
    "recursion"
  ],
  "description": "Invert a binary tree (swap left and right children recursively).",
  "examples": [
    {
      "input": "root = [4,2,7,1,3,6,9]",
      "output": "[4,7,2,9,6,3,1]"
    }
  ],
  "starterCode": "function invertTree(root) {\n  // your code here\n}",
  "solution": "function invertTree(root) {\n  if (!root) return null;\n  \n  [root.left, root.right] = [invertTree(root.right), invertTree(root.left)];\n  \n  return root;\n}",
  "hints": [
    "Base case: null returns null",
    "Swap left and right subtrees",
    "Recursively invert both subtrees"
  ],
  "testCases": [
    {
      "input": [
        {
          "val": 4,
          "left": {
            "val": 2,
            "left": {
              "val": 1,
              "left": null,
              "right": null
            },
            "right": {
              "val": 3,
              "left": null,
              "right": null
            }
          },
          "right": {
            "val": 7,
            "left": {
              "val": 6,
              "left": null,
              "right": null
            },
            "right": {
              "val": 9,
              "left": null,
              "right": null
            }
          }
        }
      ],
      "expected": {
        "val": 4,
        "left": {
          "val": 7,
          "left": {
            "val": 9,
            "left": null,
            "right": null
          },
          "right": {
            "val": 6,
            "left": null,
            "right": null
          }
        },
        "right": {
          "val": 2,
          "left": {
            "val": 3,
            "left": null,
            "right": null
          },
          "right": {
            "val": 1,
            "left": null,
            "right": null
          }
        }
      }
    }
  ],
  "functionName": "invertTree",
