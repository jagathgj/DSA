{
  "id": "tree-height",
  "title": "Find Height of Binary Tree",
  "difficulty": "Easy",
  "tags": [
    "tree",
    "recursion"
  ],
  "description": "Given root of binary tree, return its height (number of edges on longest path from root to leaf).",
  "examples": [
    {
      "input": "root = [3,9,20,null,null,15,7]",
      "output": "2"
    }
  ],
  "starterCode": "function maxDepth(root) {\n  // your code here\n}",
  "solution": "function maxDepth(root) {\n  if (!root) return 0;\n  return 1 + Math.max(maxDepth(root.left), maxDepth(root.right));\n}",
  "hints": [
    "Base case: null node has height 0",
    "Height = 1 + max(left height, right height)",
    "Use recursion"
  ],
  "testCases": [
    {
      "input": [
        {
          "val": 3,
          "left": {
            "val": 9,
            "left": null,
            "right": null
          },
          "right": {
            "val": 20,
            "left": {
              "val": 15,
              "left": null,
              "right": null
            },
            "right": {
              "val": 7,
              "left": null,
              "right": null
            }
          }
        }
      ],
      "expected": 2
    }
  ],
  "functionName": "maxDepth",
  "xpReward": 70
}